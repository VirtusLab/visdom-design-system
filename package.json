{
  "name": "@virtuslab/visdom-ui",
  "version": "0.1.4",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/VirtusLab/visdom-design-system.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./tailwind-content": "./dist/*.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly && node -e \"const fs=require('fs');['dist/index.js','dist/index.cjs'].forEach(f=>{const c=fs.readFileSync(f,'utf8');fs.writeFileSync(f,'\\\"use client\\\";\\n'+c)});fs.copyFileSync('src/styles/globals.css','dist/styles.css')\"",
    "build:storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "framer-motion": "^11.0.0 || ^12.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "framer-motion": {
      "optional": true
    }
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.576.0",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@tailwindcss/vite": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.5.0",
    "framer-motion": "^12.34.4",
    "jsdom": "^29.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^8.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^6",
    "vite-plugin-dts": "^4",
    "vitest": "^4"
  }
}
